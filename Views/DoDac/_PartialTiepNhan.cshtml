@* _PartialTiepNhan.cshtml - Hoàn toàn dùng API, không cần @model hay ViewBag *@

<div class="card border-0 shadow-none">
    <div class="card-header bg-light py-2">
        <h6 class="mb-0 text-primary fw-bold">TIẾP NHẬN HỒ SƠ ĐO ĐẠC MỚI</h6>
    </div>
    <div class="card-body">
        <div class="row g-3">

            <div class="col-md-6">
                <label class="small fw-bold">Đăng ký tại đơn vị</label>
                <div class="input-group input-group-sm">
                    <select id="tn_selectDonVi" class="form-select" disabled>
                        <option value="">Đang tải đơn vị...</option>
                    </select>
                    <div class="input-group-text">
                        <input type="checkbox" id="tn_chkOtherUnit" class="form-check-input mt-0 me-1">
                        <span class="small">Đơn vị khác</span>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <label class="small fw-bold">Quy trình xử lý <span class="text-danger">*</span></label>
                <select id="tn_IDQuyTrinh" class="form-select form-select-sm">
                    <option value="">Đang tải quy trình...</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="small fw-bold">Số hợp đồng</label>
                <div class="input-group input-group-sm">
                    <input type="text" id="tn_SoHopDong" class="form-control" readonly
                           placeholder="Nhấp nút lấy số..." />
                    <button class="btn btn-outline-primary" type="button" onclick="tn_LaySoHopDong()">
                        <i class="bi bi-arrow-repeat"></i> Lấy số
                    </button>
                </div>
            </div>

            <div class="col-md-3">
                <label class="small fw-bold">Ngày hợp đồng</label>
                <input type="text" id="tn_NgayHopDong" class="form-control form-control-sm"
                       placeholder="dd/MM/yyyy" />
            </div>

            <div class="col-md-4">
                <label class="small fw-bold">Tổ chức, cá nhân đăng ký</label>
                <input type="text" id="tn_NguoiDangKy" class="form-control form-control-sm" required />
            </div>
            <div class="col-md-4">
                <label class="small fw-bold">Số CC/CCCD/CMND</label>
                <input type="text" id="tn_CCCD" class="form-control form-control-sm" />
            </div>
            <div class="col-md-4">
                <label class="small fw-bold">Số điện thoại liên hệ</label>
                <input type="text" id="tn_SoDienThoai" class="form-control form-control-sm" />
            </div>

            <div class="col-md-3">
                <label class="small fw-bold">Tỉnh/Thành</label>
                <select id="tn_IDTinh" class="form-select form-select-sm">
                    <option value="">Đang tải tỉnh...</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="small fw-bold">Xã/Phường</label>
                <select id="tn_IDXa" class="form-select form-select-sm">
                    <option value="">-- Chọn Xã --</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="small fw-bold">Địa chỉ thửa đất</label>
                <input type="text" id="tn_DiaChiThuaDat" class="form-control form-control-sm" />
            </div>

            <div class="col-md-4">
                <label class="small fw-bold">Số phát hành GCN (nếu có)</label>
                <input type="text" id="tn_SeriGCN" class="form-control form-control-sm" />
            </div>
            <div class="col-md-8">
                <label class="small fw-bold">Mục đích đăng ký</label>
                <input type="text" id="tn_MucDich" class="form-control form-control-sm"
                       placeholder="VD: Cấp đổi, chuyển nhượng..." />
            </div>

            <div class="col-md-12">
                <label class="small fw-bold">Ghi chú</label>
                <textarea id="tn_GhiChu" class="form-control form-control-sm" rows="2"></textarea>
            </div>
        </div>

        <div class="mt-3 text-end">
            <button type="button" class="btn btn-secondary btn-sm me-2"
                    onclick="loadTask('XuLy', null)">
                Hủy bỏ
            </button>
            <button type="button" class="btn btn-primary btn-sm" onclick="tn_Submit()">
                <i class="bi bi-save"></i> Lưu hồ sơ tiếp nhận
            </button>
        </div>
    </div>
</div>

<script>
    // ============================================================
    // KHỞI TẠO PARTIAL TIẾP NHẬN
    // Gọi sau khi HTML đã render xong: await tn_Init()
    // ============================================================
    async function tn_Init() {
        // Set ngày hôm nay
        const now = new Date();
        const today = `${String(now.getDate()).padStart(2,'0')}/${String(now.getMonth()+1).padStart(2,'0')}/${now.getFullYear()}`;
        $('#tn_NgayHopDong').val(today);

        // Load dropdown song song
        await Promise.all([
            tn_LoadDonVi(),
            tn_LoadQuyTrinh(),
            tn_LoadTinh()
        ]);

        // Sự kiện checkbox "Đơn vị khác"
        $('#tn_chkOtherUnit').off('change').on('change', function () {
            $('#tn_selectDonVi').prop('disabled', !this.checked);
        });

        // Sự kiện đổi tỉnh → load xã
        $('#tn_IDTinh').off('change').on('change', function () {
            tn_LoadXa($(this).val());
        });
    }

        async function tn_LoadQuyTrinh() {
        try {
            // { id, tenQuyTrinh, loaiQuyTrinh }
            const data = await apiGet('/api/admin/QuyTrinh');
            let opts = '<option value="">-- Chọn quy trình --</option>';
            (data || []).forEach(q => {
                opts += `<option value="${q.id}">${q.tenQuyTrinh}</option>`;
            });
            $('#tn_IDQuyTrinh').html(opts);
        } catch(e) {
            $('#tn_IDQuyTrinh').html('<option value="">-- Lỗi tải --</option>');
        }
    }

    async function tn_LoadDonVi() {
        try {
            // GET /api/dodac/dropdown/all-donvi → DonViByTinhDto[]
            const data = await apiGet('/api/dodac/dropdown/all-donvi');
            let opts = '<option value="">-- Chọn đơn vị --</option>';
            (data || []).forEach(d => {
                opts += `<option value="${d.id}">${d.ten}</option>`;
            });
            $('#tn_selectDonVi').html(opts);
        } catch (e) {
            $('#tn_selectDonVi').html('<option value="">-- Lỗi tải đơn vị --</option>');
            console.error('Lỗi tải đơn vị:', e);
        }
    }

    async function tn_LoadTinh() {
        try {
            // GET /api/dodac/dropdown/all-tinh
            const data = await apiGet('/api/dodac/dropdown/all-tinh');
            let opts = '<option value="">-- Chọn Tỉnh --</option>';
            (data || []).forEach(t => {
                opts += `<option value="${t.id}">${t.ten}</option>`;
            });
            $('#tn_IDTinh').html(opts);
        } catch (e) {
            $('#tn_IDTinh').html('<option value="">-- Lỗi tải tỉnh --</option>');
            console.error('Lỗi tải tỉnh:', e);
        }
    }

    async function tn_LoadXa(idTinh) {
        $('#tn_IDXa').html('<option value="">Đang tải...</option>');
        if (!idTinh) {
            $('#tn_IDXa').html('<option value="">-- Chọn Xã --</option>');
            return;
        }
        try {
            // GET /api/dodac/dropdown/xa-by-tinh/{tinhId} → XaByTinhDto[]
            const data = await apiGet(`/api/dodac/dropdown/xa-by-tinh/${idTinh}`);
            let opts = '<option value="">-- Chọn Xã --</option>';
            (data || []).forEach(x => {
                opts += `<option value="${x.id}">${x.tenXa}</option>`;
            });
            $('#tn_IDXa').html(opts);
        } catch (e) {
            $('#tn_IDXa').html('<option value="">-- Lỗi tải xã --</option>');
        }
    }

    async function tn_LaySoHopDong() {
        const idDonVi = $('#tn_selectDonVi').val();
        if (!idDonVi) {
            alert('Chưa xác định được đơn vị để cấp số!');
            return;
        }
        if (!confirm('Hệ thống sẽ cấp số hợp đồng mới. Số sau khi lấy sẽ lưu vào CSDL, không hủy được. Tiếp tục?')) return;

        try {
            // GET /api/dodac/hosododac/next-sohopdong/{idDonVi}
            const res = await apiGet(`/api/dodac/hosododac/next-sohopdong/${idDonVi}`);
            if (res && res.soHopDong) {
                $('#tn_SoHopDong').val(res.soHopDong)
                                  .removeClass('is-invalid')
                                  .addClass('is-valid');
            } else {
                alert('Không lấy được số hợp đồng. Vui lòng thử lại!');
            }
        } catch (e) {
            alert('Lỗi kết nối: ' + e.message);
        }
    }

    async function tn_Submit() {
        // Validate tối thiểu
        const nguoiDangKy = $('#tn_NguoiDangKy').val().trim();
        const soHopDong   = $('#tn_SoHopDong').val().trim();
        const idDonVi     = $('#tn_selectDonVi').val();
        const idQuyTrinh = parseInt($('#tn_IDQuyTrinh').val()) || 0;
    if (!idQuyTrinh) { alert('Vui lòng chọn quy trình xử lý!'); return; }

        if (!nguoiDangKy) { alert('Vui lòng nhập tên tổ chức/cá nhân đăng ký!'); return; }
        if (!soHopDong)   { alert('Vui lòng lấy số hợp đồng trước!'); return; }

        // Map đúng CreateHoSoDoDacDto
        const dto = {
            idDonViCongTac: parseInt(idDonVi) || null,
            soHopDong:      soHopDong,
            idQuyTrinh: idQuyTrinh,
            ngayHopDong:    $('#tn_NgayHopDong').val(),
            nguoiDangKy:    nguoiDangKy,
            cccd:           $('#tn_CCCD').val(),
            soDienThoai:    $('#tn_SoDienThoai').val(),
            mucDichDangKy:  $('#tn_MucDich').val(),
            diaChiThuaDat:  $('#tn_DiaChiThuaDat').val(),
            idXa:           parseInt($('#tn_IDXa').val())   || null,
            idTinh:         parseInt($('#tn_IDTinh').val()) || null,
            ghiChu:         $('#tn_GhiChu').val(),
            chkOtherUnit:   $('#tn_chkOtherUnit').is(':checked')
        };

        try {
            // POST /api/dodac/hosododac
            const res = await apiPost('/api/dodac/hosododac', dto);
            if (res && res.success) {
                alert('Tiếp nhận hồ sơ thành công! Mã hồ sơ: ' + res.id);
                // Quay về tab Xử lý và reload danh sách
                loadTask('XuLy', null);
                await renderDanhSachHoSo(true);
            } else {
                alert('Lỗi lưu hồ sơ: ' + (res?.message || 'Không xác định'));
            }
        } catch (e) {
            alert('Lỗi kết nối: ' + e.message);
        }
    }
</script>

    function filterTable(value) {
        if (currentTask !== 'XuLy') return;
        if (!value) { renderBangHoSo(allHoSoData); return; }
        const filtered = allHoSoData.filter(hs =>
            (hs.soHopDong   || '').toLowerCase().includes(value) ||

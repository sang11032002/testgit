            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-success" onclick="thucHienXuatExcelDSBanVe()">
                    <i class="bi bi-download"></i> Tải file báo cáo
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Loader overlay -->
<div id="loader-overlay" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%;
     background:rgba(255,255,255,0.7); z-index:9999; justify-content:center; align-items:center; flex-direction:column;">
    <div class="clock-loader"></div>
    <div class="mt-3 fw-bold text-success">Đang xử lý dữ liệu, vui lòng đợi...</div>
</div>

<style>
    .btn-xs {
        padding: 0.2rem 0.4rem;
        font-size: 0.75rem;
        border-radius: 0.2rem;
    }

    .clock-loader {
        width: 60px;
        height: 60px;
        border: 3px solid #198754;
        border-radius: 50%;
        position: relative;
    }

        .clock-loader::after {
            content: "";
            position: absolute;
            background-color: #198754;
            top: 5px;
            left: 48%;
            width: 3px;
            height: 25px;
            transform-origin: bottom;
            animation: clock-spin 2s linear infinite;
        }

    @@keyframes clock-spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }
</style>

<script>
    // ============================================================
    // STATE
    // ============================================================
    var currentTask   = 'XuLy';
    var currentPage   = 1;
    var currentHoSoId = 0;
    var allHoSoData   = [];

    // UserId từ session — inject 1 lần lúc render Razor
    var SESSION_USER_ID = @(HttpContextAccessor.HttpContext?.Session?.GetInt32("UserId") ?? 0);

    // ============================================================
    // HELPER: gọi API chung
    // ============================================================
    async function apiGet(url) {
        const res = await fetch(url);
        if (res.status === 401) { window.location.href = '/Account/Login'; return null; }
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        return res.json();
    }

    async function apiPost(url, body) {
        const res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        if (res.status === 401) { window.location.href = '/Account/Login'; return null; }
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        return res.json();
    }

    async function apiDelete(url) {
        const res = await fetch(url, { method: 'DELETE' });
        if (res.status === 401) { window.location.href = '/Account/Login'; return null; }
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        return res.json();
    }

    function showLoader(selector) {
        $(selector).html('<div class="p-5 text-center"><div class="spinner-border text-primary"></div><p class="mt-2">Đang tải...</p></div>');
    }

    // "dd/MM/yyyy" → "dd/MM/yyyy" (giữ nguyên, API nhận dd/MM/yyyy)
    // Dùng khi cần convert sang ISO: formatDateToISO
    function formatDateToISO(str) {
        if (!str) return '';
        const p = str.split('/');
        return p.length === 3 ? `${p[2]}-${p[1]}-${p[0]}` : str;
    }

    // ============================================================
    // KHỞI TẠO TRANG
    // ============================================================
    $(document).ready(function () {
        loadDanhSachTinhVaoDropdowns();
        loadTask('XuLy', null);

        $(document).on('keyup', '#txtSearch', function () {
            filterTable($(this).val().toLowerCase());
        });
    });

    // ============================================================
    // LOAD TỈNH VÀO TẤT CẢ DROPDOWN CẦN
    // ============================================================
    async function loadDanhSachTinhVaoDropdowns() {
        try {
            const data = await apiGet('/api/dodac/dropdown/all-tinh');
            if (!data) return;
            // sel_Tinh: cho modal Quản lý số hiệu
            let optsTinh = '<option value="">-- Chọn Tỉnh --</option>';
            data.forEach(t => { optsTinh += `<option value="${t.id}">${t.ten}</option>`; });
            $('#sel_Tinh').html(optsTinh);
            // xuat_IDTinh: cho modal Xuất DS bản vẽ
            $('#xuat_IDTinh').html('<option value="">-- Chọn tỉnh --</option>' +
                data.map(t => `<option value="${t.id}">${t.ten}</option>`).join(''));
        } catch (e) {
            console.error('Lỗi tải tỉnh:', e);
        }
    }

    // ============================================================
    // MENU: LOAD TASK
    // ============================================================
        // ✅ Đổi thành async function, tách case XuLy và TiepNhan
    async function loadTask(taskName, el) {
        currentTask = taskName;
        currentPage = 1;

        $('#menuDoDac a').removeClass('active');
        if (el) $(el).addClass('active');

        const tieuDe = {
            TiepNhan: 'Tiếp nhận hồ sơ',
            XuLy:     'Hồ sơ đang xử lý',
            TraCuu:   'Tra cứu hồ sơ',
            BaoCao:   'Tổng hợp, báo cáo'
        };
        $('#lblTieuDeVung').text(tieuDe[taskName] || taskName);

        switch (taskName) {
            case 'XuLy':
                await renderDanhSachHoSo(true);   // ✅ gọi đúng hàm cho tab Xử lý
                break;

            case 'TiepNhan':
                try {
                    const res = await fetch('/DoDac/FormTiepNhan');
                    if (!res.ok) throw new Error(`HTTP ${res.status}`);
                    $('#vungNoiDung').html(await res.text());
                    await tn_Init();
                } catch (e) {
                    $('#vungNoiDung').html(
                        `<div class="alert alert-danger m-3">Lỗi tải form tiếp nhận: ${e.message}</div>`
                    );
                }
                break;

            case 'TraCuu':
                await renderTraCuu();
                break;

            case 'BaoCao':
    try {
        const res = await fetch('/DoDac/FormBaoCao');
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        $('#vungNoiDung').html(await res.text());
        await bc_Init();
    } catch(e) {
        $('#vungNoiDung').html(
            `<div class="alert alert-danger m-3">Lỗi tải báo cáo: ${e.message}</div>`
        );
    }
    break;
        }
    }

    // ============================================================
    // DANH SÁCH HỒ SƠ (XuLy / TiepNhan)
    // ============================================================
    async function renderDanhSachHoSo(onlyChuaKetThuc = true) {
        showLoader('#vungNoiDung');
        try {
            const data = await apiGet(`/api/dodac/hosododac?onlyChuaKetThuc=${onlyChuaKetThuc}`);
            if (!data) return;
            allHoSoData = data;
            renderBangHoSo(data);
        } catch (e) {
            $('#vungNoiDung').html('<div class="alert alert-danger m-3">Lỗi tải danh sách hồ sơ: ' + e.message + '</div>');
        }
    }

    function renderBangHoSo(data) {
        const pageSize   = parseInt($('#main_PageSize').val()) || 10;
        const total      = data.length;
        const totalPages = Math.ceil(total / pageSize);
        const page       = Math.min(currentPage, totalPages || 1);
        const paged      = data.slice((page - 1) * pageSize, page * pageSize);

        let rows = '';
        if (paged.length === 0) {
            rows = '<tr><td colspan="4" class="text-center text-muted py-4">Không có hồ sơ nào</td></tr>';
        } else {
            paged.forEach(hs => {
                // ── Thông tin hồ sơ ──────────────────────────────────
                const colHoSo = `

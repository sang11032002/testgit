        function moModalXinSo() {
        const $selXa = $('#bv_IDXa');
        const idXa   = $selXa.val();
        const tenXa  = $selXa.find('option:selected').text();
        // ĐỌC maXa từ data attribute (đã lưu lúc render option)
        const maXa   = $selXa.find('option:selected').data('maxa');

        if (!idXa) { alert('Vui lòng chọn Xã/Phường trước!'); return; }
        if (!maXa) { alert('Không tìm thấy mã xã. Vui lòng chọn lại!'); return; }

        $('#sh_TenXa_Display').val(tenXa);
        // Lưu maXa thật sự (string) vào hidden field
        $('#sh_MaXa_Hidden').val(maXa);
        $('#sh_Nam').val(new Date().getFullYear());
        $('#resultArea').addClass('d-none');
        new bootstrap.Modal(document.getElementById('modalSoManh')).show();
    }

        async function thucThiXinSo() {
        const maXa = $('#sh_MaXa_Hidden').val();
        const nam  = parseInt($('#sh_Nam').val());

        if (!maXa) { alert('Không có mã xã. Vui lòng đóng và chọn lại!'); return; }
        if (!nam)  { alert('Vui lòng nhập năm đo đạc!'); return; }

        try {
            const res = await apiPost('/api/dodac/somanh/create', { maXa, nam });
            if (res && res.success === true) {
                // Service trả { success: true, soMoi: number }
                const soMoi = res.soMoi;
                $('#txtSoHieuMoi').text(soMoi ?? '---');
                $('#resultArea').removeClass('d-none');
                if (soMoi) {
                    // Gán vào đúng field — bv2_SoHieuBanVe hoặc bv_SoHieuBanVe
                    const target = window._bv2_SoHieuTarget || '#bv_SoHieuBanVe';
                    $(target).val(soMoi);
                    window._bv2_SoHieuTarget = null;
                    alert('Số hiệu vừa xin được là: ' + soMoi);
                }
            } else {
                alert('Lỗi: ' + (res?.message || 'Không xác định'));
            }
        } catch (e) {
            alert('Lỗi kết nối: ' + e.message);
        }
    }


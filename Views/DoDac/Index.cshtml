    async function loadSoHieuMax() {
        const idTinh = $('#sel_Tinh').val();
        const nam    = $('#sel_Nam').val();
        if (!idTinh) { alert('Vui lòng chọn Tỉnh!'); return; }

        const tbody = $('#tbodySoHieuMax');
        tbody.html('<tr><td colspan="4" class="text-center"><div class="spinner-border spinner-border-sm text-primary"></div> Đang tra cứu...</td></tr>');

        try {
            // GET /api/dodac/somanh/sohieu-max?idTinh=&nam= → { success, data: SoHieuMaxDto[] }
            const res = await apiGet(`/api/dodac/somanh/sohieu-max?idTinh=${idTinh}&nam=${nam}`);
            if (!res || !res.success) { alert('Lỗi: ' + (res?.message || '')); return; }

            if (!res.data || res.data.length === 0) {
                tbody.html('<tr><td colspan="4" class="text-center text-muted">Không tìm thấy dữ liệu</td></tr>');
                return;
            }
            tbody.html(res.data.map(item => `
                <tr>
                    <td class="fw-bold">${item.maXa}</td>
                    <td>${item.tenXa}</td>
                    <td class="text-center">
                        <span class="badge ${item.soHieuMax > 0 ? 'bg-danger' : 'bg-secondary'}">${item.soHieuMax}</span>
                    </td>
                    <td class="text-center">
                        <button class="btn btn-outline-info btn-sm" onclick="xemChiTietSoHieu('${item.maXa}', '${item.tenXa}')">
                            <i class="bi bi-eye"></i> Xem
                        </button>
                    </td>
                </tr>`).join(''));
        } catch (e) {
            tbody.html('<tr><td colspan="4" class="text-center text-danger">Lỗi: ' + e.message + '</td></tr>');
        }
    }

    async function xemChiTietSoHieu(maXa, tenXa) {
        const nam = $('#sel_Nam').val();
        $('#lblTenXa').text(`${tenXa} (${nam})`);

        const tbody = $('#tbodyChiTietSoHieu');
        tbody.html('<tr><td colspan="4" class="text-center">Đang tải...</td></tr>');
        new bootstrap.Modal(document.getElementById('modalChiTietSoHieu')).show();

        try {
            // GET /api/dodac/somanh/lichsu?maXa=&nam= → LichSuCapSoDto[]
            const res = await apiGet(`/api/dodac/somanh/lichsu?maXa=${maXa}&nam=${nam}`);
            if (!res || res.length === 0) {
                tbody.html('<tr><td colspan="4" class="text-center text-muted">Chưa có lịch sử</td></tr>');
                return;
            }
            // FIX: dùng đúng field từ LichSuCapSoDto { shBanVe, ngayLay, tenCanBo, tenDonVi }
            tbody.html(res.map(item => `
                <tr>
                    <td class="text-center fw-bold text-danger">${item.shBanVe ?? ''}</td>
                    <td>${item.tenCanBo ?? ''}</td>
                    <td class="small">${item.ten ?? ''}</td>
                    <td class="text-muted">${item.ngayLay ?? ''}</td>
                </tr>`).join(''));

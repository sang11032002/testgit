                    <span class="badge bg-info text-dark mb-1">${hs.trangThaiDo || 'N/A'}</span><br>
                    <span class="small">Ngày giao: ${ngayGiao}</span><br>
                    <span class="small">Ngày hẹn: <b>${ngayYeuCau}</b></span>`;


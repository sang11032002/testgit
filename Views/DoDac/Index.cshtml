@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Xử lý hồ sơ đo đạc";
    var canBo = HttpContextAccessor.HttpContext?.Session?.GetString("FullName") ?? "Chưa đăng nhập";
    var donVi = HttpContextAccessor.HttpContext?.Session?.GetString("DonViCongTac") ?? "Chưa xác định";
    var tenChucVu = HttpContextAccessor.HttpContext?.Session?.GetString("ChucVu") ?? "";
}

<div class="card shadow-sm mb-3 border-0 bg-light">
    <div class="card-body py-2 d-flex justify-content-between align-items-center">
        <div class="header-info d-flex align-items-center">
            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary btn-sm me-3">
                <i class="bi bi-house-door-fill"></i> Trang chủ
            </a>
            <span>Cán bộ xử lý: <b>@canBo</b></span>
            <span class="mx-2">|</span>
            <span>Đơn vị: <b>@donVi</b></span>
        </div>
        <div class="badge bg-primary">Thời điểm đăng nhập: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</div>
    </div>
</div>

<div class="row">
    <div class="col-md-3">
        <div class="list-group shadow-sm" id="menuDoDac">
            @if (true)
            {
                <a href="javascript:void(0)" class="list-group-item list-group-item-action py-3 text-success fw-bold border-top"
                   onclick="loadTask('TiepNhan', this)">Tiếp nhận hồ sơ</a>
            }
            <a href="javascript:void(0)" class="list-group-item list-group-item-action py-3 text-success fw-bold border-top"
               onclick="loadTask('XuLy', this)">Xử lý hồ sơ</a>
            <a href="javascript:void(0)" class="list-group-item list-group-item-action py-3 text-success fw-bold border-top"
               onclick="loadTask('TraCuu', this)">Tra cứu hồ sơ</a>
            <a href="javascript:void(0)" class="list-group-item list-group-item-action py-3 text-success fw-bold border-top"
               onclick="moModalQuanLySoHieu()"><i class="bi bi-list-ol me-2"></i>Quản lý số hiệu bản vẽ</a>
            <a href="javascript:void(0)" class="list-group-item list-group-item-action py-3 text-success fw-bold border-top"
               onclick="loadTask('BaoCao', this)">Tổng hợp, báo cáo</a>
            @if (true)
            {
                <a href="javascript:void(0)" class="list-group-item list-group-item-action py-3 text-success fw-bold border-top"
                   onclick="moModalXuatDSBanVe()">
                    <i class="bi bi-file-earmark-excel-fill me-2"></i> Xuất DS bản vẽ
                </a>
            }
        </div>
    </div>

    <div class="col-md-9">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
                <div class="row align-items-center">
                    <div class="col-md-4">
                        <h6 class="fw-bold mb-0 text-uppercase" id="lblTieuDeVung">Hồ sơ đang xử lý</h6>
                    </div>
                    <div class="col-md-8">
                        <div class="d-flex justify-content-end align-items-center">
                            <div class="d-flex align-items-center me-3">
                                <span class="small me-2">Dòng:</span>
                                <div class="input-group input-group-sm" style="width: 100px;">
                                    <button class="btn btn-outline-primary" onclick="changeMainPageSize(-5)">-</button>
                                    <input type="text" id="main_PageSize" class="form-control text-center bg-white" value="10" readonly>
                                    <button class="btn btn-outline-primary" onclick="changeMainPageSize(5)">+</button>
                                </div>
                            </div>
                            <div class="input-group input-group-sm" style="width: 250px;">
                                <input type="text" id="txtSearch" class="form-control" placeholder="Tìm tên, số hợp đồng...">
                                <button class="btn btn-primary" onclick="searchHoSo()"><i class="bi bi-search"></i></button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body p-0" id="vungNoiDung">
                <div class="p-5 text-center">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-2">Đang tải dữ liệu...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===================== MODALS ===================== -->

<div class="modal fade" id="modalXuLy" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="bi bi-gear-wide-connected"></i> XỬ LÝ HỒ SƠ</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="contentXuLy"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalLichSu" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title"><i class="bi bi-clock-history"></i> LỊCH SỬ XỬ LÝ</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" id="contentLichSu"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalHSQuet" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-file-earmark-pdf"></i> QUẢN LÝ FILE ĐÍNH KÈM</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" id="contentHSQuet"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalBanVe" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-secondary text-white">
                <h5 class="modal-title"><i class="bi bi-map"></i> BẢN VẼ</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" id="modalBanVeContent"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalSoManh" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white py-2">
                <h6 class="modal-title">Cấp Số Hiệu Tự Động</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="sh_MaXa_Hidden" />
                <div class="mb-3">
                    <label class="small fw-bold">Địa danh (Xã/Phường) — kiểm tra kỹ trước khi lấy số:</label>
                    <input type="text" id="sh_TenXa_Display" class="form-control bg-light" readonly />
                </div>
                <div class="mb-3">
                    <label class="small fw-bold">Năm đo đạc:</label>
                    <input type="number" id="sh_Nam" class="form-control" value="@DateTime.Now.Year" />
                </div>
                <div id="resultArea" class="mt-3 p-2 border rounded bg-light d-none text-center">
                    <span class="small text-muted">Số hiệu vừa cấp:</span><br />
                    <strong class="text-danger h3" id="txtSoHieuMoi">---</strong>
                </div>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-success w-100" onclick="thucThiXinSo()">
                    <i class="bi bi-magic"></i> THỰC HIỆN XIN SỐ
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalQuanLySoHieu" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Quản lý số hiệu bản vẽ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-2 mb-3">
                    <div class="col-md-5">
                        <label class="small fw-bold">Chọn Tỉnh:</label>
                        <select id="sel_Tinh" class="form-select form-select-sm">
                            <option value="">-- Đang tải tỉnh... --</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="small fw-bold">Chọn Năm:</label>
                        <select id="sel_Nam" class="form-select form-select-sm">
                            @for (int i = DateTime.Now.Year; i >= 2020; i--)
                            {
                                <option value="@i">Năm @i</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button class="btn btn-primary btn-sm w-100" onclick="loadSoHieuMax()">
                            <i class="bi bi-search"></i> Xem danh sách
                        </button>
                    </div>
                </div>
                <div class="table-responsive" style="max-height: 400px;">
                    <table class="table table-sm table-bordered table-hover">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>Mã Xã</th>
                                <th>Tên Xã/Phường</th>
                                <th class="text-center">Số hiệu lớn nhất</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="tbodySoHieuMax">
                            <tr><td colspan="4" class="text-center text-muted">Chọn tỉnh và nhấn Xem danh sách</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalChiTietSoHieu" tabindex="-1" style="z-index: 1060;">
    <div class="modal-dialog modal-md shadow-lg">
        <div class="modal-content">
            <div class="modal-header bg-info text-white py-2">
                <h6 class="modal-title">Lịch sử cấp số: <span id="lblTenXa"></span></h6>
                <button type="button" class="btn-close" onclick="bootstrap.Modal.getInstance(document.getElementById('modalChiTietSoHieu')).hide()"></button>
            </div>
            <div class="modal-body p-0">
                <table class="table table-sm table-striped mb-0" style="font-size: 0.8rem;">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center">Số hiệu</th>
                            <th>Cán bộ lấy số</th>
                            <th>Đơn vị</th>
                            <th>Ngày lấy</th>
                        </tr>
                    </thead>
                    <tbody id="tbodyChiTietSoHieu"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalThanhLy" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title"><i class="bi bi-file-earmark-word-fill"></i> CHỌN TEMPLATE THANH LÝ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">1. Chọn mẫu Word (.docx)</label>
                    <input type="file" id="fileTemplateThanhLy" class="form-control" accept=".docx" />
                </div>
                <div class="row g-2 mt-1">
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">Tên file xuất</label>
                        <input type="text" id="tenFileXuat" class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">Ngày lập (dd/mm/yyyy)</label>
                        <input type="text" id="inpNgayLap" class="form-control"
                               placeholder="dd/mm/yyyy" value="@DateTime.Now.ToString("dd/MM/yyyy")" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small">Tổng tiền thanh lý</label>
                        <input type="number" id="tienThanhLy" class="form-control" value="0" oninput="tinhTienConLai()">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small">Tiền đã ứng</label>
                        <input type="number" id="tienUng" class="form-control" value="0" oninput="tinhTienConLai()">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small">Tiền còn lại</label>
                        <input type="number" id="tienConLai" class="form-control" value="0" readonly>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-warning fw-bold" id="btnXuatHoSo" onclick="xuatHoSoThanhLy()">
                    <i class="bi bi-download"></i> Xuất hồ sơ
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalXuatDSBanVe" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="bi bi-file-earmark-excel"></i> XUẤT DANH SÁCH BẢN VẼ CHI TIẾT</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">Từ ngày</label>
                        <input type="text" id="xuat_TuNgay" class="form-control"
                               placeholder="dd/MM/yyyy" value="@DateTime.Now.ToString("01/01/yyyy")" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">Đến ngày</label>
                        <input type="text" id="xuat_DenNgay" class="form-control"
                               placeholder="dd/MM/yyyy" value="@DateTime.Now.ToString("dd/MM/yyyy")" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold">Tình trạng thanh toán</label>
                        <select id="xuat_TrangThaiTT" class="form-select">
                            <option value="all">-- Tất cả --</option>
                            <option value="true">Đã thanh toán</option>
                            <option value="false">Chưa thanh toán</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold">Tỉnh/Thành</label>
                        <select id="xuat_IDTinh" class="form-select" onchange="loadDonViTheoTinh(this.value, 'xuat_IDDonVi')">
                            <option value="">-- Chọn tỉnh --</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold">Đơn vị công tác</label>
                        <select id="xuat_IDDonVi" class="form-select">

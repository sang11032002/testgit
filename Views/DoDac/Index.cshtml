        $sel.html('<option value="0">Đang tải...</option>');
        try {
            const data = await apiGet(`/api/dodac/dropdown/donvi-by-tinh/${idTinh}`);
            let opts = '<option value="0">-- Tất cả đơn vị --</option>';
            (data || []).forEach(d => { opts += `<option value="${d.id}">${d.ten}</option>`; });
            $sel.html(opts);
        } catch (e) {
            $sel.html('<option value="0">-- Lỗi tải --</option>');
        }
    }

    async function thucHienXuatExcelDSBanVe() {
        const tuNgayStr  = $('#xuat_TuNgay').val();
        const denNgayStr = $('#xuat_DenNgay').val();
        if (!tuNgayStr || !denNgayStr) { alert('Vui lòng nhập khoảng thời gian!'); return; }

        // FIX: XuatExcelThanhToanRequestDto { TuNgay(DateTime), DenNgay(DateTime), DaThanhToan, IdTinh, IdDonVi }
        // Convert dd/MM/yyyy → ISO để C# parse được DateTime
        const body = {
            tuNgay:      formatDateToISO(tuNgayStr),
            denNgay:     formatDateToISO(denNgayStr),
            daThanhToan: $('#xuat_TrangThaiTT').val(),          // "all" | "true" | "false"
            idTinh:      parseInt($('#xuat_IDTinh').val())  || null,
            idDonVi:     parseInt($('#xuat_IDDonVi').val()) || null
        };

        $('#loader-overlay').css('display', 'flex');
        try {
            // POST /api/dodac/xuatfile/excel-thanhtoan
            const res = await fetch('/api/dodac/xuatfile/excel-thanhtoan', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(body)
            });
            if (!res.ok) throw new Error(`HTTP ${res.status}`);

            const blob = await res.blob();
            const url  = URL.createObjectURL(blob);
            const a    = document.createElement('a');
            a.href = url;
            a.download = `BaoCao_ThanhToan_${new Date().toISOString().slice(0, 10)}.xlsx`;
            document.body.appendChild(a); a.click();
            URL.revokeObjectURL(url); a.remove();

            bootstrap.Modal.getInstance(document.getElementById('modalXuatDSBanVe')).hide();
        } catch (e) {
            alert('Lỗi xuất Excel: ' + e.message);
        } finally {
            $('#loader-overlay').hide();
        }
    }
</script>

                            <th style="width:20%">Quy trình & Thời hạn</th>
                            <th style="width:25%">Thông tin xử lý</th>
                            <th style="width:30%">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="tableHoSoBody">${rows}</tbody>
                </table>
            </div>
            ${pagination}
        `);
    }

    // ── Helpers ngày tháng ───────────────────────────────────────────
    function formatDisplayDate(val) {
        // Nhận DateOnly kiểu "2024-01-21", ISO "2024-01-21T..." hoặc "21/01/2024" → "21/01/2024"
        if (!val) return '';
        const s = String(val);
        if (s.includes('/')) return s;
        const date = s.split('T')[0]; // "2024-01-21"
        const [y, m, d] = date.split('-');
        return `${d}/${m}/${y}`;
    }

    function diffDay(val) {
        // val có thể là DateOnly "2024-01-21" hoặc ISO string
        const s = String(val).split('T')[0];
        const target = new Date(s);
        const today  = new Date(); today.setHours(0, 0, 0, 0);
        return Math.round((target - today) / 86400000);
    }


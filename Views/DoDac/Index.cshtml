    async function renderHSQuet(idHoSo) {
        showLoader('#contentHSQuet');
        try {
            const data = await apiGet(`/api/dodac/FileQuet/by-hoso/${idHoSo}`);
            if (!data) return;

            let rows = '';
            if (data.length === 0) {
                rows = '<tr><td colspan="3" class="text-center text-muted py-3">Chưa có file đính kèm</td></tr>';
            } else {
                rows = data.map(f => `
                    <tr>
                        <td>${f.tenFileLuu || ''}</td>
                        <td>${f.noiDungSoBo || ''}</td>
                        <td class="text-center">
                            <a href="/api/dodac/FileQuet/view/${f.id}" target="_blank"
                               class="btn btn-xs btn-outline-primary me-1">
                                <i class="bi bi-eye"></i> Xem
                            </a>
                            <button class="btn btn-xs btn-outline-danger" onclick="xoaFileQuet(${f.id}, ${idHoSo})">
                                <i class="bi bi-trash"></i> Xóa
                            </button>
                        </td>
                    </tr>`).join('');
            }

            $('#contentHSQuet').html(`
                <div class="p-3">
                    <div class="table-responsive mb-3">
                        <table class="table table-sm table-bordered">
                            <thead class="table-light">
                                <tr><th>Tên file</th><th>Nội dung</th><th class="text-center" style="width:130px">Thao tác</th></tr>
                            </thead>
                            <tbody>${rows}</tbody>
                        </table>
                    </div>
                    <hr>
                    <div class="row g-2">
                        <div class="col-md-4">
                            <label class="small fw-bold">Nội dung sơ bộ</label>
                            <input type="text" id="fq_NoiDung" class="form-control form-control-sm" placeholder="Ghi chú file...">
                        </div>
                        <div class="col-md-5">
                            <label class="small fw-bold">Chọn file</label>
                            <input type="file" id="fq_File" class="form-control form-control-sm">
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <button class="btn btn-primary btn-sm w-100" onclick="uploadFileQuet(${idHoSo})">
                                <i class="bi bi-upload"></i> Tải lên
                            </button>
                        </div>
                    </div>
                </div>`);
        } catch (e) {
            $('#contentHSQuet').html('<div class="alert alert-danger m-3">Lỗi tải file đính kèm: ' + e.message + '</div>');
        }
    }

    async function uploadFileQuet(idHoSo) {
        const fileInput = document.getElementById('fq_File');
        if (!fileInput.files.length) { alert('Vui lòng chọn file!'); return; }

        const formData = new FormData();
        formData.append('idHoSo', idHoSo);
        formData.append('noiDung', $('#fq_NoiDung').val() || '');
        formData.append('file', fileInput.files[0]);

        try {
            const res = await fetch('/api/dodac/FileQuet/upload', { method: 'POST', body: formData });
            const json = await res.json();
            if (json.success) {
                await renderHSQuet(idHoSo);
            } else {
                alert('Lỗi upload: ' + (json.message || 'Không xác định'));
            }
        } catch (e) {
            alert('Lỗi kết nối: ' + e.message);
        }
    }

    async function xoaFileQuet(id, idHoSo) {
        if (!confirm('Bạn có chắc muốn xóa file này không?')) return;
        try {
            const json = await apiDelete(`/api/dodac/FileQuet/${id}`);
            if (json && json.success) {
                await renderHSQuet(idHoSo);
            } else {
                alert('Không xóa được: ' + (json?.message || ''));
            }
        } catch (e) {
            alert('Lỗi kết nối: ' + e.message);
        }
    }


    async function thucHienTongHop() {
        const tuNgay  = $('#bc_TuNgay').val();
        const denNgay = $('#bc_DenNgay').val();
        if (!tuNgay || !denNgay) { alert('Vui lòng nhập khoảng thời gian!'); return; }

        // FIX: BaoCaoRequestDto nhận dd/MM/yyyy trực tiếp, không cần convert ISO
        const body = {
            tuNgay,
            denNgay,
            idTinh:  parseInt($('#bc_IDTinh').val())  || null,
            idDonVi: parseInt($('#bc_IDDonVi').val()) || null
        };

        showLoader('#vungKetQuaBaoCao');
        try {
            // POST /api/dodac/baocao/thongke → trả về object có các mảng ThongKe*Dto
            const res = await apiPost('/api/dodac/baocao/thongke', body);
            if (!res) return;
            $('#vungKetQuaBaoCao').html(renderThongKe(res));
        } catch (e) {
            $('#vungKetQuaBaoCao').html('<div class="alert alert-danger">Lỗi tổng hợp: ' + e.message + '</div>');
        }
    }

    function renderThongKe(data) {
        // API trả về object gồm các mảng: trangThai[], canBo[], banVe[]
        // Tương ứng ThongKeTrangThaiDto, ThongKeCanBoDto, ThongKeBanVeDto
        let html = '';

        // ── Thống kê theo trạng thái ─────────────────────────────
        if (data.trangThai && data.trangThai.length > 0) {
            html += `<h6 class="fw-bold text-muted mb-2">THEO TRẠNG THÁI HỒ SƠ</h6>
                <div class="row g-2 mb-4">`;
            data.trangThai.forEach(tt => {
                html += `
                <div class="col-md-3 col-6">
                    <div class="card border-0 shadow-sm text-center p-2"
                        style="border-left: 4px solid ${tt.mauSac || '#6c757d'} !important;">
                        <div class="h4 fw-bold mb-0" style="color:${tt.mauSac || '#6c757d'}">${tt.soLuong}</div>
                        <div class="small text-muted">${tt.tenTrangThai}</div>
                        <div class="mt-1" style="font-size:.75rem;">
                            <span class="text-success">Còn hạn: ${tt.conHan}</span> |
                            <span class="text-danger">Quá hạn: ${tt.quaHan}</span>
                        </div>
                    </div>
                </div>`;
            });
            html += '</div>';
        }

        // ── Thống kê theo cán bộ ──────────────────────────────────
        if (data.canBo && data.canBo.length > 0) {
            html += `<h6 class="fw-bold text-muted mb-2">THEO CÁN BỘ XỬ LÝ</h6>
                <div class="table-responsive mb-4">
                <table class="table table-sm table-bordered table-hover">
                    <thead class="table-light">
                        <tr><th>Cán bộ</th>
                            <th class="text-center">Tổng</th>
                            <th class="text-center">Đã xong</th>
                            <th class="text-center">Đang làm</th>
                            <th class="text-center text-danger">Quá hạn</th>
                        </tr>
                    </thead>
                    <tbody>`;
            data.canBo.forEach(cb => {
                html += `<tr>
                    <td>${cb.tenCanBo}</td>
                    <td class="text-center fw-bold">${cb.tong}</td>
                    <td class="text-center text-success">${cb.daXong}</td>
                    <td class="text-center text-primary">${cb.dangLam}</td>
                    <td class="text-center text-danger">${cb.quaHan}</td>
                </tr>`;
            });
            html += '</tbody></table></div>';
        }

        // ── Thống kê theo loại bản vẽ ─────────────────────────────
        if (data.banVe && data.banVe.length > 0) {
            html += `<h6 class="fw-bold text-muted mb-2">THEO LOẠI BẢN VẼ</h6>
                <div class="table-responsive">
                <table class="table table-sm table-bordered table-hover">
                    <thead class="table-light">
                        <tr><th>Loại bản vẽ</th><th class="text-center">Tổng số</th><th>Chi tiết trạng thái</th></tr>
                    </thead>
                    <tbody>`;
            data.banVe.forEach(bv => {
                const chiTiet = (bv.chiTietTrangThai || [])
                    .map(ct => `<span class="badge bg-light text-dark border me-1">${ct.tenTrangThai}: ${ct.soLuong}</span>`)
                    .join('');
                html += `<tr>
                    <td>${bv.tenLoai}</td>
                    <td class="text-center fw-bold">${bv.tongSo}</td>
                    <td>${chiTiet}</td>
                </tr>`;
            });
            html += '</tbody></table></div>';
        }

        if (!html) {
            html = '<p class="text-center text-muted">Không có dữ liệu thống kê.</p>';
        }

        return html;
    }


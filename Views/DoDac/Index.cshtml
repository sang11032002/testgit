                        </button>
                        <button class="btn btn-xs btn-outline-success mb-1" onclick="openBanVeModal(${hs.id})" title="Bản vẽ">
                            <i class="bi bi-map"></i> Bản vẽ
                        </button>
                        <button class="btn btn-xs btn-outline-warning" onclick="moModalThanhLy(${hs.id})" title="Tạo văn bản Word">
                            <i class="bi bi-file-word"></i> Tạo Văn bản (Word)
                        </button>
                    </div>`;

                rows += `
                <tr>
                    <td style="width:25%">${colHoSo}</td>
                    <td style="width:20%">${colQuyTrinh}</td>
                    <td style="width:25%">${colXuLy}</td>
                    <td style="width:30%">${colThaotac}</td>
                </tr>`;
            });
        }

        // ── Phân trang ───────────────────────────────────────────────
        let pagination = '';
        if (totalPages > 1) {
            const maxBtn = 5;
            const half   = Math.floor(maxBtn / 2);
            let start    = Math.max(1, page - half);
            let end      = Math.min(totalPages, start + maxBtn - 1);
            if (end - start < maxBtn - 1) start = Math.max(1, end - maxBtn + 1);

            let btns = '';
            if (start > 1) btns += `<li class="page-item"><a class="page-link" href="javascript:void(0)" onclick="goPage(1)">1</a></li>
                                     <li class="page-item disabled"><span class="page-link">…</span></li>`;
            for (let p = start; p <= end; p++) {
                btns += `<li class="page-item ${p === page ? 'active' : ''}">
                            <a class="page-link" href="javascript:void(0)" onclick="goPage(${p})">${p}</a></li>`;
            }
            if (end < totalPages) btns += `<li class="page-item disabled"><span class="page-link">…</span></li>
                                            <li class="page-item"><a class="page-link" href="javascript:void(0)" onclick="goPage(${totalPages})">${totalPages}</a></li>`;

            pagination = `
            <div class="card-footer bg-white border-top py-2">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="small text-muted">
                        Hiển thị <b>${paged.length}</b> / <b>${total}</b> hồ sơ
                        (Trang <b>${page}</b>/<b>${totalPages}</b>)

    function moModalThanhLy(id) {
        currentHoSoId = id;
        $('#fileTemplateThanhLy').val('');
        $('#tenFileXuat').val('ThanhLy_' + id);
        $('#tienThanhLy, #tienUng, #tienConLai').val(0);

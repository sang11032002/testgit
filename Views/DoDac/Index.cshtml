    function tinhTienConLai() {
        var tong = parseFloat($('#tienThanhLy').val()) || 0;
        var ung  = parseFloat($('#tienUng').val())     || 0;
        $('#tienConLai').val(tong - ung);
    }

    async function xuatHoSoThanhLy() {
        const fileInput = document.getElementById('fileTemplateThanhLy');
        const tenFile   = ($('#tenFileXuat').val() || '').trim();
        const ngayLap   = $('#inpNgayLap').val();

        if (!fileInput.files.length) { alert('Vui lòng chọn file mẫu .docx!'); return; }
        if (!tenFile)                 { alert('Vui lòng nhập tên file xuất!'); return; }
        if (!ngayLap)                 { alert('Vui lòng nhập ngày lập!'); return; }

        const btn = $('#btnXuatHoSo');
        btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Đang xử lý...');

        // FIX: map đúng field XuatWordThanhLyRequestDto
        const formData = new FormData();
        formData.append('templateFile',    fileInput.files[0]);
        formData.append('idDangKyDoDac',   currentHoSoId);
        formData.append('fileNameOut',     tenFile);
        formData.append('ngayLapStr',      ngayLap);
        formData.append('tongTien',        $('#tienThanhLy').val() || 0);
        formData.append('tienUng',         $('#tienUng').val()     || 0);

        try {
            const res = await fetch('/api/dodac/xuatfile/word-thanhly', { method: 'POST', body: formData });
            if (!res.ok) { throw new Error(await res.text()); }

            const blob = await res.blob();
            const url  = URL.createObjectURL(blob);
            const a    = document.createElement('a');
            a.href = url; a.download = tenFile + '.docx';
            document.body.appendChild(a); a.click();
            URL.revokeObjectURL(url); a.remove();

            bootstrap.Modal.getInstance(document.getElementById('modalThanhLy')).hide();
        } catch (e) {
            alert('Lỗi xuất file: ' + e.message);
        } finally {
            btn.prop('disabled', false).html('<i class="bi bi-download"></i> Xuất hồ sơ');
        }
    }


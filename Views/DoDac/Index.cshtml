        async function thucHienTraCuu() {
        showLoader('#vungKetQuaTraCuu');
        const tuKhoa  = ($('#tc_TuKhoa').val() || '').toLowerCase();
        const idDonVi = parseInt($('#tc_IDDonVi').val()) || 0;
        const body = {
            idDonVi: idDonVi || null,
            tuNgay:  $('#tc_TuNgay').val() || '01/01/2020',
            denNgay: $('#tc_DenNgay').val() || `31/12/${new Date().getFullYear()}`
        };

        try {
            let data = await apiPost('/api/dodac/baocao/chitiet', body);
            if (!data) return;

            if (tuKhoa) {
                data = data.filter(hs =>
                    (hs.soHopDong   || '').toLowerCase().includes(tuKhoa) ||
                    (hs.nguoiDangKy || '').toLowerCase().includes(tuKhoa) ||
                    (hs.tenXa       || '').toLowerCase().includes(tuKhoa)
                );
            }

            allTraCuuData     = data;   // ← lưu riêng
            currentTraCuuPage = 1;
            renderBangTraCuu(allTraCuuData);
        } catch (e) {
            $('#vungKetQuaTraCuu').html('<div class="alert alert-danger">Lỗi tìm kiếm: ' + e.message + '</div>');
        }
    }

        // HÀM MỚI: renderBangTraCuu — phân trang riêng cho Tra cứu
    // ============================================================
    function renderBangTraCuu(data) {
        const pageSize   = parseInt($('#main_PageSize').val()) || 10;
        const total      = data.length;
        const totalPages = Math.ceil(total / pageSize);
        const page       = Math.min(currentTraCuuPage, totalPages || 1);
        const paged      = data.slice((page - 1) * pageSize, page * pageSize);

        if (total === 0) {
            $('#vungKetQuaTraCuu').html('<p class="text-center text-muted">Không tìm thấy kết quả.</p>');
            return;
        }

        const rows = paged.map((hs, i) => `
            <tr>
                <td>${(page - 1) * pageSize + i + 1}</td>
                <td class="fw-bold text-primary">${hs.soHopDong || ''}</td>
                <td>${hs.nguoiDangKy || ''}</td>
                <td>${hs.ngayHopDong ? formatDisplayDate(hs.ngayHopDong) : ''}</td>
                <td>${hs.diaChiThuaDat || ''}</td>
                <td>${hs.tenXa || ''}</td>
                <td>${hs.tenDonViCongTac || ''}</td>
                <td><span class="badge bg-secondary">${hs.trangThaiDo || ''}</span></td>
                <td>${hs.tenNguoiXuLy || '---'}</td>
                <td>${hs.ngayYeuCau ? formatDisplayDate(hs.ngayYeuCau) : ''}</td>
                <td>${hs.ngayDo ? formatDisplayDate(hs.ngayDo) : ''}</td>
                <td>${hs.ngayTraKetQua ? formatDisplayDate(hs.ngayTraKetQua) : ''}</td>
                <td class="text-center">
                    <button class="btn btn-sm btn-outline-primary" onclick="openXuLy(${hs.id})">
                        <i class="bi bi-pencil-square"></i>
                    </button>
                </td>
            </tr>`).join('');

        // ── Phân trang ──────────────────────────────────────────────
        let pagination = '';
        if (totalPages > 1) {
            const maxBtn = 5, half = Math.floor(maxBtn / 2);
            let start = Math.max(1, page - half);
            let end   = Math.min(totalPages, start + maxBtn - 1);
            if (end - start < maxBtn - 1) start = Math.max(1, end - maxBtn + 1);

            let btns = '';
            if (start > 1) btns += `<li class="page-item"><a class="page-link" href="javascript:void(0)" onclick="goTraCuuPage(1)">1</a></li>
                                     <li class="page-item disabled"><span class="page-link">…</span></li>`;
            for (let p = start; p <= end; p++) {
                btns += `<li class="page-item ${p === page ? 'active' : ''}">
                            <a class="page-link" href="javascript:void(0)" onclick="goTraCuuPage(${p})">${p}</a></li>`;
            }
            if (end < totalPages) btns += `<li class="page-item disabled"><span class="page-link">…</span></li>
                                            <li class="page-item"><a class="page-link" href="javascript:void(0)" onclick="goTraCuuPage(${totalPages})">${totalPages}</a></li>`;

            pagination = `
            <div class="d-flex justify-content-between align-items-center mt-2 px-1">
                <span class="small text-muted">
                    Hiển thị <b>${paged.length}</b> / <b>${total}</b> hồ sơ
                    (Trang <b>${page}</b>/<b>${totalPages}</b>)
                </span>
                <nav><ul class="pagination pagination-sm mb-0">
                    <li class="page-item ${page <= 1 ? 'disabled' : ''}">
                        <a class="page-link" href="javascript:void(0)" onclick="goTraCuuPage(${page - 1})">‹</a></li>
                    ${btns}
                    <li class="page-item ${page >= totalPages ? 'disabled' : ''}">
                        <a class="page-link" href="javascript:void(0)" onclick="goTraCuuPage(${page + 1})">›</a></li>
                </ul></nav>
            </div>`;
        }

        $('#vungKetQuaTraCuu').html(`
            <div class="table-responsive">
                <table class="table table-sm table-hover table-bordered" style="font-size:.82rem;">
                    <thead class="table-light">
                        <tr>
                            <th>#</th><th>Số HĐ</th><th>Chủ sử dụng</th><th>Ngày ĐK</th>
                            <th>Địa chỉ</th><th>Xã/Phường</th><th>Đơn vị</th><th>Trạng thái</th>
                            <th>Người GQ</th><th>Ngày hẹn</th><th>Ngày đo</th><th>Ngày trả KQ</th><th></th>
                        </tr>
                    </thead>
                    <tbody>${rows}</tbody>
                </table>
            </div>
            ${pagination}
        `);
    }


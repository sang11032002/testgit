@* Views/DoDac/_PartialBaoCao.cshtml *@
@* Không cần @@model — toàn bộ dữ liệu lấy qua API *@

<div class="p-3" id="vungBaoCao">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3 border-bottom">
            <h6 class="fw-bold mb-0 text-primary text-uppercase">
                <i class="bi bi-file-earmark-bar-graph me-2"></i>Tổng hợp &amp; Báo cáo hồ sơ
            </h6>
        </div>
        <div class="card-body">

            @* ── BỘ LỌC ───────────────────────────────────────────── *@
            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <label class="small fw-bold mb-1">Tỉnh/Thành phố:</label>
                    <select id="bc_IDTinh" class="form-select form-select-sm shadow-sm">
                        <option value="">-- Tất cả các tỉnh --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="small fw-bold mb-1">Đơn vị công tác:</label>
                    <select id="bc_IDDonVi" class="form-select form-select-sm shadow-sm">
                        <option value="">-- Chọn Tỉnh/TP trước --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="small fw-bold mb-1">Từ ngày:</label>
                    <input type="text" id="bc_TuNgay" class="form-control form-control-sm shadow-sm"
                           placeholder="dd/MM/yyyy" maxlength="10" />
                </div>
                <div class="col-md-2">
                    <label class="small fw-bold mb-1">Đến ngày:</label>
                    <input type="text" id="bc_DenNgay" class="form-control form-control-sm shadow-sm"
                           placeholder="dd/MM/yyyy" maxlength="10" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary btn-sm w-100 fw-bold shadow-sm"
                            onclick="bc_ThucHienTongHop()">
                        <i class="bi bi-calculator me-1"></i> TỔNG HỢP
                    </button>
                </div>
            </div>

            <hr />

            @* ── KẾT QUẢ ──────────────────────────────────────────── *@
            <div id="bc_VungKetQua">
                <div class="alert alert-info text-center py-4">
                    <i class="bi bi-info-circle fs-4 d-block mb-2"></i>
                    Vui lòng chọn điều kiện và nhấn nút <b>Tổng hợp</b> để xem dữ liệu.
                </div>
            </div>

        </div>
    </div>
</div>

@* ── MODAL CHI TIẾT HỒ SƠ ────────────────────────────────── *@
<div class="modal fade" id="bc_ModalChiTiet" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="bc_ModalTitle">Chi tiết hồ sơ</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" id="bc_ModalBody"></div>
            <div class="modal-footer py-2">
                <button class="btn btn-success btn-sm" onclick="bc_XuatExcel()">
                    <i class="bi bi-file-earmark-excel me-1"></i> Xuất Excel
                </button>
                <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<script>
    // ================================================================
    // STATE nội bộ của Partial BaoCao
    // ================================================================
    var bc_CurrentTrangThai = '';
    var bc_CurrentStaffId   = null;

    // ================================================================
    // ENTRY POINT — Index.cshtml gọi hàm này sau khi inject HTML
    // ================================================================
    async function bc_Init() {
        // Set ngày mặc định: từ đầu tháng đến hôm nay
        const now  = new Date();
        const dd   = String(now.getDate()).padStart(2, '0');
        const mm   = String(now.getMonth() + 1).padStart(2, '0');
        const yyyy = now.getFullYear();
        $('#bc_TuNgay').val(`01/${mm}/${yyyy}`);
        $('#bc_DenNgay').val(`${dd}/${mm}/${yyyy}`);

        // Load danh sách tỉnh vào dropdown riêng của partial
        await bc_LoadTinh();

        // Bind sự kiện đổi tỉnh → load đơn vị (dùng .off để tránh bind 2 lần)
        $('#bc_IDTinh').off('change').on('change', function () {
            bc_LoadDonViTheoTinh($(this).val());
        });
    }

    // ================================================================
    // LOAD TỈNH → GET /api/dodac/dropdown/all-tinh
    // Response: DropdownDto[] { id, ten }
    // ================================================================
    async function bc_LoadTinh() {
        try {
            const data = await apiGet('/api/dodac/dropdown/all-tinh');
            if (!data) return;
            let opts = '<option value="">-- Tất cả các tỉnh --</option>';
            data.forEach(t => { opts += `<option value="${t.id}">${t.ten}</option>`; });
            $('#bc_IDTinh').html(opts);
        } catch (e) {
            console.error('bc_LoadTinh lỗi:', e);
        }
    }

    // ================================================================
    // LOAD ĐƠN VỊ THEO TỈNH → GET /api/dodac/dropdown/donvi-by-tinh/{idTinh}
    // Response: DonViByTinhDto[] { id, tenDonVi }
    // ================================================================
    async function bc_LoadDonViTheoTinh(idTinh) {
        const $sel = $('#bc_IDDonVi');
        if (!idTinh) {
            $sel.html('<option value="">-- Chọn Tỉnh/TP trước --</option>');
            return;
        }
        $sel.html('<option value="">Đang tải...</option>');
        try {
            const data = await apiGet(`/api/dodac/dropdown/donvi-by-tinh/${idTinh}`);
            let opts = '<option value="">-- Tất cả đơn vị --</option>';
            (data || []).forEach(d => {
                opts += `<option value="${d.id}">${d.tenDonVi}</option>`;
            });
            $sel.html(opts);
        } catch (e) {
            $sel.html('<option value="">-- Lỗi tải --</option>');
        }
    }

    // ================================================================
    // TỔNG HỢP → POST /api/dodac/baocao/thongke
    // Body: BaoCaoRequestDto { idTinh, idDonVi, tuNgay (dd/MM/yyyy), denNgay }
    // Response: { trangThai: ThongKeTrangThaiDto[], canBo: ThongKeCanBoDto[], banVe: ThongKeBanVeDto[] }
    // ================================================================
    async function bc_ThucHienTongHop() {
        const tuNgay  = $('#bc_TuNgay').val();
        const denNgay = $('#bc_DenNgay').val();
        if (!tuNgay || !denNgay) {
            alert('Vui lòng nhập khoảng thời gian!');
            return;
        }

        $('#bc_VungKetQua').html(`
            <div class="text-center p-5">
                <div class="spinner-border text-primary"></div>
                <p class="mt-2">Đang tổng hợp dữ liệu...</p>
            </div>`);

        const body = {
            idTinh:  parseInt($('#bc_IDTinh').val())  || null,
            idDonVi: parseInt($('#bc_IDDonVi').val()) || null,
            tuNgay,
            denNgay
        };

        try {
            const raw = await apiPost('/api/dodac/baocao/thongke', body);
            if (!raw) return;

            // Map đúng tên field API trả về → tên dùng trong render
            const res = {
                trangThai: raw.thongKeTrangThai || [],
                canBo:     raw.thongKeCanBo     || [],
                banVe:     raw.thongKeBanVe     || []
            };

            $('#bc_VungKetQua').html(bc_RenderDashboard(res, tuNgay, denNgay));
            bc_VeChart(res.trangThai);
        } catch (e) {
            $('#bc_VungKetQua').html(
                `<div class="alert alert-danger">Lỗi tổng hợp: ${e.message}</div>`);
        }
    }

    // ================================================================
    // RENDER DASHBOARD ĐẦY ĐỦ
    // ================================================================
    function bc_RenderDashboard(data, tuNgay, denNgay) {
        const trangThai = data.trangThai || [];
        const canBo     = data.canBo    || [];
        const banVe     = data.banVe    || [];
        const tongSo    = trangThai.reduce((s, t) => s + (t.soLuong || 0), 0);

        // ── Cards trạng thái ─────────────────────────────────────────
        let cardsHTML = '';
        trangThai.forEach(tt => {
            const mau = tt.mauSac || '#6c757d';
            cardsHTML += `
            <div class="col-md-6">
                <div class="card shadow-sm border-0 border-top border-4 h-100"
                     style="border-top-color:${mau} !important;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="fw-bold text-muted small">${tt.tenTrangThai || ''}</span>
                            <h3 class="fw-bold mb-0" style="color:${mau}">${tt.soLuong}</h3>
                        </div>
                        <div class="row g-0 py-2 border-top border-bottom my-2 bg-light">
                            <div class="col-6 text-center border-end">
                                <small class="text-muted d-block small">Còn hạn</small>
                                <b class="text-success">${tt.conHan}</b>
                            </div>
                            <div class="col-6 text-center">
                                <small class="text-muted d-block small">Quá hạn</small>
                                <b class="text-danger">${tt.quaHan}</b>
                            </div>
                        </div>
                        <a href="javascript:void(0)"
                           onclick="bc_MoModalTheoTrangThai('${(tt.tenTrangThai || '').replace(/'/g, "\\'")}')"
                           class="text-decoration-none small fw-bold">
                            <u>Xem danh sách</u> <i class="bi bi-chevron-right"></i>
                        </a>
                    </div>
                </div>
            </div>`;
        });

        // ── Bảng cán bộ ──────────────────────────────────────────────
        const rowsCanBo = canBo.length === 0
            ? '<tr><td colspan="6" class="text-center text-muted p-3">Không có dữ liệu</td></tr>'
            : canBo.map(cb => `
            <tr>
                <td class="ps-3"><b>${cb.tenCanBo || ''}</b></td>
                <td class="text-center">${cb.tong}</td>
                <td class="text-center text-success">${cb.daXong}</td>
                <td class="text-center text-primary">${cb.dangLam}</td>
                <td class="text-center fw-bold text-danger">${cb.quaHan}</td>
                <td class="text-center">
                    <button class="btn btn-outline-primary btn-xs"
                        onclick="bc_MoModalTheoCanBo(${cb.idTaiKhoanDo}, '${(cb.tenCanBo || '').replace(/'/g, "\\'")}')">
                        <i class="bi bi-list-check"></i> Xem &amp; Xuất Excel
                    </button>
                </td>
            </tr>`).join('');

        // ── Bảng bản vẽ ──────────────────────────────────────────────
        const rowsBanVe = banVe.length === 0
            ? `<tr>
                   <td colspan="3" class="text-center py-5 text-muted">
                       <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                       Không tìm thấy dữ liệu bản vẽ phù hợp.
                   </td>
               </tr>`
            : banVe.map(bv => {
                const chiTiet = (bv.chiTietTrangThai || [])
                    .map(ct => `<span class="badge border text-dark me-1">${ct.tenTrangThai}: ${ct.soLuong}</span>`)
                    .join('');
                return `
                <tr>
                    <td class="ps-3">${bv.tenLoai || ''}</td>
                    <td class="text-center fw-bold">${bv.tongSo}</td>
                    <td>${chiTiet}</td>
                </tr>`;
            }).join('');

        return `
        <div class="row mb-3">
            <div class="col-md-8">
                <h5 class="fw-bold text-primary">
                    <i class="bi bi-graph-up-arrow me-2"></i>
                    TỔNG HỢP HỒ SƠ (${tuNgay} - ${denNgay})
                </h5>
            </div>
            <div class="col-md-4 text-end">
                <span class="badge bg-dark p-2">Tổng cộng: ${tongSo} hồ sơ</span>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-7">
                <div class="row g-3">${cardsHTML}</div>
            </div>
            <div class="col-md-5">
                <div class="card shadow-sm border-0 p-3 h-100 d-flex align-items-center justify-content-center">
                    <canvas id="bc_Chart" style="max-height:250px; width:100%;"></canvas>
                </div>
            </div>
        </div>

        <hr />

        <h6 class="fw-bold text-secondary mb-3">
            <i class="bi bi-people me-2"></i>THỐNG KÊ THEO CÁN BỘ XỬ LÝ
        </h6>
        <div class="table-responsive mb-4">
            <table class="table table-sm table-hover border">
                <thead class="table-light small">
                    <tr>
                        <th class="ps-3">Họ và tên cán bộ</th>
                        <th class="text-center">Tổng</th>
                        <th class="text-center text-success">Đã xong</th>
                        <th class="text-center text-primary">Đang xử lý</th>
                        <th class="text-center text-danger">Quá hạn</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody class="small">${rowsCanBo}</tbody>
            </table>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3 border-bottom">
                <h6 class="fw-bold mb-0 text-success text-uppercase">
                    <i class="bi bi-layers-half me-2"></i>Thống kê bản vẽ theo loại &amp; trạng thái
                </h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3" style="width:250px">Loại bản vẽ</th>
                                <th class="text-center" style="width:120px">Tổng số</th>
                                <th>Chi tiết theo trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>${rowsBanVe}</tbody>
                    </table>
                </div>
            </div>
        </div>`;
    }

    // ================================================================
    // VẼ BIỂU ĐỒ DOUGHNUT (Chart.js load sẵn trong _Layout.cshtml)
    // ================================================================
    function bc_VeChart(trangThaiArr) {
        setTimeout(() => {
            const el = document.getElementById('bc_Chart');
            if (!el || typeof Chart === 'undefined') return;

            // Huỷ chart cũ trước khi vẽ lại
            if (window.bc_ChartInstance) {
                window.bc_ChartInstance.destroy();
            }

            window.bc_ChartInstance = new Chart(el.getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels:   trangThaiArr.map(t => t.tenTrangThai || ''),
                    datasets: [{
                        data:            trangThaiArr.map(t => t.soLuong || 0),
                        backgroundColor: trangThaiArr.map(t => t.mauSac  || '#6c757d'),
                        borderWidth: 2,
                        borderColor: '#ffffff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { boxWidth: 12, font: { size: 11 } }
                        }
                    },
                    cutout: '70%'
                }
            });
        }, 150); // Chờ DOM render canvas xong
    }

    // ================================================================
    // MỞ MODAL THEO TRẠNG THÁI HỒ SƠ
    // ================================================================
    function bc_MoModalTheoTrangThai(tenTrangThai) {
        bc_CurrentTrangThai = tenTrangThai;
        bc_CurrentStaffId   = null;
        $('#bc_ModalTitle').text('DANH SÁCH HỒ SƠ: ' + tenTrangThai);
        bc_HienThiModal();
    }

    // ================================================================
    // MỞ MODAL THEO CÁN BỘ XỬ LÝ
    // ================================================================
    function bc_MoModalTheoCanBo(idTaiKhoan, tenCanBo) {
        bc_CurrentTrangThai = '';
        bc_CurrentStaffId   = idTaiKhoan;
        $('#bc_ModalTitle').text('DANH SÁCH HỒ SƠ CỦA: ' + tenCanBo);
        bc_HienThiModal();
    }

    // ================================================================
    // LOAD DỮ LIỆU VÀ HIỆN MODAL CHI TIẾT
    // POST /api/dodac/baocao/chitiet?trangThai=...&idNhanVien=...
    // Body: BaoCaoRequestDto
    // ================================================================
    async function bc_HienThiModal() {
        $('#bc_ModalBody').html(`
            <div class="text-center p-5">
                <div class="spinner-border text-primary"></div>
                <p class="mt-2">Đang tải dữ liệu...</p>
            </div>`);

        bootstrap.Modal.getOrCreateInstance(
            document.getElementById('bc_ModalChiTiet')
        ).show();

        const body = {
            idTinh:  parseInt($('#bc_IDTinh').val())  || null,
            idDonVi: parseInt($('#bc_IDDonVi').val()) || null,
            tuNgay:  $('#bc_TuNgay').val(),
            denNgay: $('#bc_DenNgay').val()
        };

        // [FromQuery] trong BaoCaoController.GetDanhSachChiTiet
        const params = new URLSearchParams();
        if (bc_CurrentTrangThai) params.set('trangThai',  bc_CurrentTrangThai);
        if (bc_CurrentStaffId)   params.set('idNhanVien', bc_CurrentStaffId);

        try {
            const res = await fetch(`/api/dodac/baocao/chitiet?${params.toString()}`, {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(body)
            });
            if (res.status === 401) { window.location.href = '/Account/Login'; return; }
            if (!res.ok) throw new Error(`HTTP ${res.status}`);

            const data = await res.json();
            $('#bc_ModalBody').html(bc_RenderBangChiTiet(data));
        } catch (e) {
            $('#bc_ModalBody').html(
                `<div class="alert alert-danger m-3">Lỗi tải danh sách: ${e.message}</div>`);
        }
    }

    // ================================================================
    // RENDER BẢNG DANH SÁCH HỒ SƠ CHI TIẾT TRONG MODAL
    // Dùng lại formatDisplayDate() đã định nghĩa trong Index.cshtml
    // ================================================================
    function bc_RenderBangChiTiet(data) {
        if (!data || data.length === 0) {
            return '<p class="text-center text-muted p-4">Không tìm thấy hồ sơ phù hợp.</p>';
        }

        const rows = data.map((hs, i) => `
        <tr>
            <td class="text-center">${i + 1}</td>
            <td class="fw-bold text-primary">${hs.soHopDong || ''}</td>
            <td>${hs.nguoiDangKy || ''}</td>
            <td>${hs.ngayHopDong     ? formatDisplayDate(hs.ngayHopDong)     : ''}</td>
            <td>${hs.diaChiThuaDat   || ''}</td>
            <td>${hs.tenXa           || ''}</td>
            <td>${hs.tenDonViCongTac || ''}</td>
            <td><span class="badge bg-secondary">${hs.trangThaiDo || ''}</span></td>
            <td>${hs.tenNguoiXuLy    || '---'}</td>
            <td>${hs.ngayYeuCau      ? formatDisplayDate(hs.ngayYeuCau)      : ''}</td>
            <td>${hs.ngayDo          ? formatDisplayDate(hs.ngayDo)          : ''}</td>
            <td>${hs.ngayTraKetQua   ? formatDisplayDate(hs.ngayTraKetQua)   : ''}</td>
            <td class="text-center">
                <button class="btn btn-xs btn-outline-primary"
                        onclick="openXuLy(${hs.id})" title="Xem &amp; chỉnh sửa">
                    <i class="bi bi-pencil-square"></i>
                </button>
            </td>
        </tr>`).join('');

        return `
        <div class="table-responsive">
            <table class="table table-sm table-hover table-bordered mb-0" style="font-size:.82rem;">
                <thead class="table-light sticky-top">
                    <tr>
                        <th class="text-center">#</th>
                        <th>Số HĐ</th>
                        <th>Chủ sử dụng</th>
                        <th>Ngày ĐK</th>
                        <th>Địa chỉ</th>
                        <th>Xã/Phường</th>
                        <th>Đơn vị</th>
                        <th>Trạng thái</th>
                        <th>Người GQ</th>
                        <th>Ngày hẹn</th>
                        <th>Ngày đo</th>
                        <th>Ngày trả KQ</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>${rows}</tbody>
            </table>
        </div>`;
    }

    // ================================================================
    // XUẤT EXCEL → POST /api/dodac/xuatfile/excel-chitiet
    // XuatExcelRequestDto: { trangThai, idDonVi, tuNgay, denNgay, idNhanVien }
    // tuNgay/denNgay giữ nguyên dd/MM/yyyy vì XuatExcelRequestDto dùng string
    // ================================================================
    async function bc_XuatExcel() {
        const body = {
            trangThai:  bc_CurrentTrangThai || null,
            idDonVi:    parseInt($('#bc_IDDonVi').val()) || null,
            tuNgay:     $('#bc_TuNgay').val(),
            denNgay:    $('#bc_DenNgay').val(),
            idNhanVien: bc_CurrentStaffId   || null
        };

        $('#loader-overlay').css('display', 'flex');
        try {
            const res = await fetch('/api/dodac/xuatfile/excel-chitiet', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(body)
            });
            if (!res.ok) throw new Error(`HTTP ${res.status}`);

            const blob = await res.blob();
            const url  = URL.createObjectURL(blob);
            const a    = document.createElement('a');
            a.href     = url;
            a.download = `BaoCao_${new Date().toISOString().slice(0, 10)}.xlsx`;
            document.body.appendChild(a);
            a.click();
            URL.revokeObjectURL(url);
            a.remove();
        } catch (e) {
            alert('Lỗi xuất Excel: ' + e.message);
        } finally {
            $('#loader-overlay').hide();
        }
    }
</script>
